{
  "name": "@waymark/nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js compiler/runtime integration for Waymark workflows",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./loader": "./src/loader/waymark-loader.js",
    "./with-waymark": "./src/with-waymark.js"
  },
  "scripts": {
    "build-proto": "mkdir -p src/generated && grpc_tools_node_protoc --proto_path=../../../proto --js_out=import_style=commonjs,binary:src/generated --grpc_out=grpc_js:src/generated ../../../proto/messages.proto ../../../proto/ast.proto",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@grpc/grpc-js": "^1.14.1",
    "google-protobuf": "^4.0.1"
  },
  "devDependencies": {
    "grpc-tools": "^1.13.0",
    "jest": "^30.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
